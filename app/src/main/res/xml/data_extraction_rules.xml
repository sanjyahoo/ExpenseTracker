<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude financial data from cloud backup (Google Drive) -->
        <exclude domain="database" path="expense_tracker_db"/>
        <exclude domain="database" path="expense_tracker_db-shm"/>
        <exclude domain="database" path="expense_tracker_db-wal"/>
        <exclude domain="sharedpref" path="app_settings.xml"/>
        <exclude domain="sharedpref" path="db_key_store.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude financial data from device-to-device transfers -->
        <exclude domain="database" path="expense_tracker_db"/>
        <exclude domain="database" path="expense_tracker_db-shm"/>
        <exclude domain="database" path="expense_tracker_db-wal"/>
        <exclude domain="sharedpref" path="app_settings.xml"/>
        <exclude domain="sharedpref" path="db_key_store.xml"/>
    </device-transfer>
</data-extraction-rules>