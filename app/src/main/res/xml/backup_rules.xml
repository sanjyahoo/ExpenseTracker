<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude the Room database — contains all financial transaction data -->
    <exclude domain="database" path="expense_tracker_db"/>
    <exclude domain="database" path="expense_tracker_db-shm"/>
    <exclude domain="database" path="expense_tracker_db-wal"/>
    <!-- Exclude app settings SharedPreferences — contains biometric lock state -->
    <exclude domain="sharedpref" path="app_settings.xml"/>
    <!-- Exclude the database key store SharedPreferences -->
    <exclude domain="sharedpref" path="db_key_store.xml"/>
</full-backup-content>